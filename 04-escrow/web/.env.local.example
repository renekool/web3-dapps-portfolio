# RPC URL to connect to the blockchain (e.g., Anvil local node)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Chain ID of the network
NEXT_PUBLIC_CHAIN_ID=31337

# Deployed Escrow contract address
NEXT_PUBLIC_ESCROW_ADDRESS=

# Deployed Mock Token A address
NEXT_PUBLIC_TOKEN_A_ADDRESS=

# Deployed Mock Token B address
NEXT_PUBLIC_TOKEN_B_ADDRESS=

# Debug flag to enable local balance simulation or extra logging
NEXT_PUBLIC_DEBUG_BALANCES=true
